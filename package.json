{
  "name": "spectral-soundworks-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "import:csv": "node scripts/import-leads-from-csv.js",
    "backfill:enrich": "node scripts/backfill-enrich.js",
    "backfill:ig-images": "node scripts/backfill-ig-images.js",
    "ig:scrape": "node scripts/ig-profile-scraper.js",
    "score": "node scripts/score-leads.js",
    "score:auto": "node scripts/score-auto.js",
    "enrich:stale": "node scripts/enrich-stale.js",
    "followup:remind": "node scripts/followup-remind.js",
    "discover:contacts": "node scripts/discover-contacts.js",
    "report:campaign": "node scripts/report-campaign.js",
    "detect:duplicates": "node scripts/detect-duplicates.js",
    "standardize:genres": "node scripts/standardize-genres.js",
    "send:messages": "node scripts/send-messages.js",
    "seed": "node prisma/seed.js",
    "seed:reset": "node prisma/seed.js --reset",
    "launch": "bash scripts/launch.sh",
    "db:backup": "docker exec spectral-postgres pg_dump -U postgres spectral > backup_$(date +%Y%m%d_%H%M%S).sql",
    "db:migrate": "prisma migrate dev",
    "test": "node --test src/**/*.test.js"
  },
  "dependencies": {
    "@novu/nextjs": "^3.16.0",
    "@novu/node": "^2.6.6",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "apify-client": "^2.15.1",
    "csv-parse": "^5.6.0",
    "imapflow": "^1.3.3",
    "mailparser": "^3.9.8",
    "next": "16.1.6",
    "nodemailer": "^6.9.13",
    "pg": "^8.18.0",
    "prisma": "^7.3.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sharp": "^0.34.3"
  },
  "devDependencies": {
    "@types/mailparser": "^3.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^6.4.14",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.5.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
